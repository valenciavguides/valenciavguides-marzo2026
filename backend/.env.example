# ====================================
# Valencia VGuides - Backend Environment
# ====================================

# Puerto del servidor
PORT=3001

# Entorno de ejecución
# Valores: development, production
NODE_ENV=development

# Dominio de producción
# Usado en validación CORS y URLs del servidor
DOMAIN=valenciavguides.es

# Certificados SSL (solo producción)
# Rutas relativas o absolutas a los archivos de certificado
CERT_PATH=./certs/cert.pem
KEY_PATH=./certs/key.pem

# ====================================
# AUTENTICACIÓN (solo producción)
# ====================================
# Activar autenticación por token (false = pass-through, true = requiere JWT)
AUTH_ENABLED=false

# Clave secreta para firmar tokens JWT (CAMBIAR en producción)
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=dev-secret-no-usar-en-produccion

# ====================================
# INSTRUCCIONES
# ====================================

# DESARROLLO:
# 1. Copiar este archivo a .env
# 2. El servidor correrá en http://localhost:3001 con CORS para localhost

# PRODUCCIÓN:
# 1. Establecer NODE_ENV=production
# 2. Establecer DOMAIN=valenciavguides.es
# 3. Copiar certificados SSL a ./certs/ (o indicar ruta en CERT_PATH/KEY_PATH)
# 4. Establecer AUTH_ENABLED=true
# 5. Generar JWT_SECRET seguro (ver comando arriba)
# 6. El servidor usará HTTPS + autenticación automáticamente

# Para generar certificados autofirmados (pruebas):
# openssl req -x509 -newkey rsa:2048 -keyout key.pem -out cert.pem -days 365 -nodes
